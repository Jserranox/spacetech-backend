DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aeroagent

# Redis
REDIS_URL=redis://localhost:6379

# Storage
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=aerobot-docs
S3_ACCESS_KEY=
S3_SECRET_KEY=

# LLM Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# Auth
JWT_SECRET=
JWT_EXPIRATION=1h

# Webhooks
# Generate with: openssl rand -hex 32
WEBHOOK_ENCRYPTION_KEY=
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_MAX_ATTEMPTS=5

# App
NODE_ENV=development
PORT=3000
